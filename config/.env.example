# ══════════════════════════════════════════════════════════════
# Polymarket Bot - Configuration
# Developed by: Carlos David Donoso Cordero (ddchack)
# ══════════════════════════════════════════════════════════════

# === POLYMARKET CREDENTIALS ===
# Export your private key from: https://reveal.magic.link/polymarket
POLYMARKET_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# Your proxy wallet address (found in Polymarket Settings > Wallet Address)
POLYMARKET_FUNDER_ADDRESS=0x_YOUR_PROXY_WALLET_ADDRESS

# Signature type: 0=EOA/MetaMask (recomendado), 1=GnosisSafe/SmartWallet proxy
# Si tu wallet_address == dirección derivada de tu private key → usa 0
# Si tu wallet_address es un contrato (GnosisSafe) diferente a tu signing key → usa 1
POLYMARKET_SIGNATURE_TYPE=0

# === API ENDPOINTS ===
CLOB_API_URL=https://clob.polymarket.com
GAMMA_API_URL=https://gamma-api.polymarket.com
DATA_API_URL=https://data-api.polymarket.com

# === TRADING PARAMETERS ===
MAX_CAPITAL_USD=100
MAX_BET_SINGLE_USD=25
KELLY_FRACTION=0.25
MIN_EXPECTED_VALUE=0.05
MIN_EDGE_PERCENT=3.0

# === LLM KEYS (optional — enables AI market analysis) ===
# Get your Anthropic key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Get your OpenAI key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here

# === NEWS SENTIMENT ===
# Free tier NewsAPI key from https://newsapi.org
NEWSAPI_KEY=your_newsapi_key_here

# === SERVER ===
BACKEND_PORT=8888
FRONTEND_PORT=3000
